<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             xmlns:models="clr-namespace:Erasmove.Models"
             x:Class="Erasmove.Views.TransportCatalogView"
             x:DataType="vm:TransportCatalogViewModel">

    <Grid RowDefinitions="*, Auto" Padding="10">
        <RefreshView Command="{Binding LoadItemsCommand}" IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Transport">
                        <HorizontalStackLayout Spacing="10" Padding="5">
                            <Label Text="{Binding Compagnie}" FontAttributes="Bold" />
                            <Label Text="{Binding TypeLibelle}" />
                            <Button Text="X" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TransportCatalogViewModel}}, Path=DeleteItemCommand}" CommandParameter="{Binding .}" />
                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button Grid.Row="1" Text="Ajouter Transport" Command="{Binding GoToAddPageCommand}" />
    </Grid>

</ContentPage>
