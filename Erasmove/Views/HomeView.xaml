<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             x:Class="Erasmove.Views.HomeView"
             x:DataType="vm:HomeViewModel">

    <Grid RowDefinitions="Auto, *" Style="{StaticResource MainContainerGrid}">
        
        <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,0,0,10">
            <Label Text="Sélectionner votre voyage" />
            <Picker ItemsSource="{Binding Items}"
                    SelectedItem="{Binding SelectedVoyage}"
                    ItemDisplayBinding="{Binding Libelle}" />
        </VerticalStackLayout>

        <mapsui:MapControl x:Name="HomeMap" Grid.Row="1" />
        
    </Grid>

</ContentPage>
