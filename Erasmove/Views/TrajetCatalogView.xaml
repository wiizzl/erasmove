<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             xmlns:models="clr-namespace:Erasmove.Models"
             x:Class="Erasmove.Views.TrajetCatalogView"
             x:DataType="vm:TrajetCatalogViewModel">
    
    <Grid RowDefinitions="*, Auto" Padding="10">
        <RefreshView Command="{Binding LoadItemsCommand}" IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Trajet">
                        <HorizontalStackLayout Spacing="10" Padding="5">
                            <Label Text="{Binding VilleDepart}" />
                            <Label Text="➔" />
                            <Label Text="{Binding VilleArrivee}" />
                            <Label Text="{Binding CompagnieTransport}" FontAttributes="Italic" />
                            <Button Text="X" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrajetCatalogViewModel}}, Path=DeleteItemCommand}" CommandParameter="{Binding .}" />
                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button Grid.Row="1" Text="Ajouter Trajet" Command="{Binding GoToAddPageCommand}" />
    </Grid>

</ContentPage>
