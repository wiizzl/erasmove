<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             x:Class="Erasmove.Views.AddTransportView"
             x:DataType="vm:AddTransportViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="32,24"
                             Spacing="12"
                             HorizontalOptions="Center"
                             MaximumWidthRequest="624">

                <Label Text="Ajouter un Transport" Style="{StaticResource TablePageTitle}" Margin="0,0,0,8" />

                <Border Style="{StaticResource FormField}">
                    <Entry Placeholder="Compagnie" Text="{Binding Compagnie}" />
                </Border>

                <Border Style="{StaticResource FormField}">
                    <Picker Title="Type de transport"
                            ItemsSource="{Binding Types}"
                            ItemDisplayBinding="{Binding Libelle}"
                            SelectedItem="{Binding SelectedType}" />
                </Border>

                <ActivityIndicator IsRunning="{Binding IsBusy}" Margin="0,4" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Text="Enregistrer" Command="{Binding SaveCommand}" />
                    <Button Grid.Column="1" Text="Annuler" Command="{Binding CancelCommand}" />
                </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
