<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             x:Class="Erasmove.Views.AddTransportView"
             x:DataType="vm:AddTransportViewModel">

    <VerticalStackLayout Padding="10" Spacing="10">
        <Entry Placeholder="Compagnie" Text="{Binding Compagnie}" />

        <Picker Title="Type de transport"
                ItemsSource="{Binding Types}"
                ItemDisplayBinding="{Binding Libelle}"
                SelectedItem="{Binding SelectedType}" />

        <ActivityIndicator IsRunning="{Binding IsBusy}" />

        <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,15,0,0">
            <Button Grid.Column="0" Text="Annuler" Command="{Binding CancelCommand}" Style="{StaticResource AddButtonStyle}" />
            <Button Grid.Column="1" Text="Enregistrer" Command="{Binding SaveCommand}" 
                    Style="{StaticResource AddButtonStyle}" />
        </Grid>
    </VerticalStackLayout>

</ContentPage>
