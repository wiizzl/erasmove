<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             x:Class="Erasmove.Views.LoginPage"
             x:DataType="vm:LoginViewModel">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
        <Label Text="Welcome to Erasmove" FontSize="24" HorizontalOptions="Center" />
        <Entry Placeholder="Username" Text="{Binding Email}" />
        <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" />
        <Label Text="{Binding ErrorMessage}" TextColor="Red" HorizontalOptions="Center" />
        <Button Text="Login" Command="{Binding LoginCommand}" />
        
    </VerticalStackLayout>

</ContentPage>
