<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Erasmove.Models"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             x:Class="Erasmove.Views.UtilisateurCatalogView"
             x:DataType="vm:UtilisateurCatalogViewModel">

    <Grid RowDefinitions="*, Auto" Padding="10">
        <RefreshView Command="{Binding LoadItemsCommand}" IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Utilisateur">
                        <Grid ColumnDefinitions="*, Auto" Padding="5,6">
                            <VerticalStackLayout Grid.Column="0" Spacing="1">
                                <Label Text="{Binding Nom}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding Prenom}" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding RoleLibelle}" TextColor="Gray" FontSize="12" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="X" VerticalOptions="Center"
                                    IsVisible="{Binding IsNotAdmin}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:UtilisateurCatalogViewModel}}, Path=DeleteItemCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button Grid.Row="1" Text="Ajouter Utilisateur" Command="{Binding GoToAddPageCommand}" />
    </Grid>

</ContentPage>
