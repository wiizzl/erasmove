<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             xmlns:models="clr-namespace:Erasmove.Models"
             x:Class="Erasmove.Views.AddVoyageView"
             x:DataType="vm:AddVoyageViewModel">

    <Grid RowDefinitions="Auto, *, Auto" Style="{StaticResource MainContainerGrid}">
        <VerticalStackLayout Grid.Row="0" Spacing="15" Margin="0,0,0,15">
            <Entry Placeholder="Intitulé" Text="{Binding Libelle}" />

            <Picker Title="Voyageur"
                    ItemsSource="{Binding Utilisateurs}"
                    ItemDisplayBinding="{Binding Nom}"
                    SelectedItem="{Binding SelectedUtilisateur}" />

            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                <Picker Grid.Column="0" Title="Lieu de départ" ItemsSource="{Binding Lieux}" ItemDisplayBinding="{Binding Nom}" SelectedItem="{Binding SelectedDepart}" />
                <Picker Grid.Column="1" Title="Lieu d'arrivée" ItemsSource="{Binding Lieux}" ItemDisplayBinding="{Binding Nom}" SelectedItem="{Binding SelectedArrivee}" />
            </Grid>

            <Button Text="Calculer l'itinéraire" Command="{Binding CalculateBestItineraryCommand}" Margin="0,10,0,0" />

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,5,0,0">
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" VerticalOptions="Center" HeightRequest="20" WidthRequest="20" />
                <Label Text="{Binding ItineraireMessage}" TextColor="{StaticResource Primary}" VerticalOptions="Center" FontAttributes="Italic" />
            </HorizontalStackLayout>
            
        </VerticalStackLayout>

        <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,15,0,0">
            <Button Grid.Column="0" Text="Annuler" Command="{Binding CancelCommand}" Style="{StaticResource AddButtonStyle}" />
            <Button Grid.Column="1" Text="Enregistrer" Command="{Binding SaveCommand}" 
                    Style="{StaticResource AddButtonStyle}" />
        </Grid>

    </Grid>

</ContentPage>
