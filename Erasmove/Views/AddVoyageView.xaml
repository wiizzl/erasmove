<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             xmlns:models="clr-namespace:Erasmove.Models"
             x:Class="Erasmove.Views.AddVoyageView"
             x:DataType="vm:AddVoyageViewModel">

    <VerticalStackLayout Padding="10" Spacing="10">
        <Picker Title="Étudiant" ItemsSource="{Binding Utilisateurs}" ItemDisplayBinding="{Binding Nom}" SelectedItem="{Binding SelectedUtilisateur}" />
        <Picker Title="Ville Départ" ItemsSource="{Binding Villes}" ItemDisplayBinding="{Binding Ville}" SelectedItem="{Binding SelectedDepart}" />
        <Picker Title="Ville Arrivée" ItemsSource="{Binding Villes}" ItemDisplayBinding="{Binding Ville}" SelectedItem="{Binding SelectedArrivee}" />

        <ActivityIndicator IsRunning="{Binding IsBusy}" />

        <Button Text="Enregistrer Voyage" Command="{Binding SaveCommand}" IsEnabled="{Binding HasResult}" />
        <Button Text="Annuler" Command="{Binding CancelCommand}" />
    </VerticalStackLayout>

</ContentPage>
