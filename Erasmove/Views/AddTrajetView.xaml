<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             x:Class="Erasmove.Views.AddTrajetView"
             x:DataType="vm:AddTrajetViewModel">

    <VerticalStackLayout Padding="10" Spacing="10">
        <Picker Title="Lieu Départ"
                ItemsSource="{Binding Lieux}"
                ItemDisplayBinding="{Binding Nom}"
                SelectedItem="{Binding SelectedDepart}" />

        <Picker Title="Lieu Arrivée"
                ItemsSource="{Binding Lieux}"
                ItemDisplayBinding="{Binding Nom}"
                SelectedItem="{Binding SelectedArrivee}" />

        <Picker Title="Transport"
                ItemsSource="{Binding Transports}"
                ItemDisplayBinding="{Binding Compagnie}"
                SelectedItem="{Binding SelectedTransport}" />

        <ActivityIndicator IsRunning="{Binding IsBusy}" />

        <Button Text="Enregistrer" Command="{Binding SaveCommand}" />
        <Button Text="Annuler" Command="{Binding CancelCommand}" />
    </VerticalStackLayout>

</ContentPage>
