<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             x:Class="Erasmove.Views.AddTrajetView"
             x:DataType="vm:AddTrajetViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="32,24"
                             Spacing="12"
                             HorizontalOptions="Center"
                             MaximumWidthRequest="560">

                <Label Text="Ajouter un Trajet" Style="{StaticResource TablePageTitle}" Margin="0,0,0,8" />

                <Border Style="{StaticResource FormField}">
                    <Picker Title="Lieu Départ"
                            ItemsSource="{Binding Lieux}"
                            ItemDisplayBinding="{Binding Nom}"
                            SelectedItem="{Binding SelectedDepart}" />
                </Border>

                <Border Style="{StaticResource FormField}">
                    <Picker Title="Lieu Arrivée"
                            ItemsSource="{Binding Lieux}"
                            ItemDisplayBinding="{Binding Nom}"
                            SelectedItem="{Binding SelectedArrivee}" />
                </Border>

                <Border Style="{StaticResource FormField}">
                    <Picker Title="Transport"
                            ItemsSource="{Binding Transports}"
                            ItemDisplayBinding="{Binding Compagnie}"
                            SelectedItem="{Binding SelectedTransport}" />
                </Border>

                <ActivityIndicator IsRunning="{Binding IsBusy}" Margin="0,4" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Text="Enregistrer" Command="{Binding SaveCommand}" />
                    <Button Grid.Column="1" Text="Annuler" Command="{Binding CancelCommand}" />
                </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
