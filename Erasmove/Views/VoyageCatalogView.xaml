<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             xmlns:models="clr-namespace:Erasmove.Models"
             x:Class="Erasmove.Views.VoyageCatalogView"
             x:DataType="vm:VoyageCatalogViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="20,16">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <Label Text="Voyages" Style="{StaticResource TablePageTitle}" />
            <Button Grid.Column="1" Text="+"
                    Style="{StaticResource AddButton}"
                    Command="{Binding GoToAddPageCommand}" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="3*,3*,50">
            <Label Grid.Column="0" Text="Libellé"     Style="{StaticResource TableHeaderLabel}" />
            <Label Grid.Column="1" Text="Utilisateur" Style="{StaticResource TableHeaderLabel}" />
        </Grid>

        <BoxView Grid.Row="2" HeightRequest="1" Margin="0,4,0,0" />

        <RefreshView Grid.Row="3"
                     Command="{Binding LoadItemsCommand}"
                     IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Voyage">
                        <VerticalStackLayout>
                            <Grid ColumnDefinitions="3*,3*,50" Padding="0,8">
                                <Label Grid.Column="0" Text="{Binding Libelle}" Style="{StaticResource TableCellLabel}" />
                                <Label Grid.Column="1" Style="{StaticResource TableCellLabel}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding UtilisateurPrenom}" />
                                            <Span Text=" " />
                                            <Span Text="{Binding UtilisateurNom}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Button Grid.Column="2" Text="🗑" Style="{StaticResource DeleteButton}"
                                        VerticalOptions="Center" HorizontalOptions="Center"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:VoyageCatalogViewModel}}, Path=DeleteItemCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                            <BoxView HeightRequest="1" Opacity="0.3" Margin="4,0" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>

</ContentPage>
