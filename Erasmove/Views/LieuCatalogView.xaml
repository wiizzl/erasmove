<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             xmlns:models="clr-namespace:Erasmove.Models"
             x:Class="Erasmove.Views.LieuCatalogView"
             x:DataType="vm:LieuCatalogViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="20,16">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <Label Text="Lieux" Style="{StaticResource TablePageTitle}" />
            <Button Grid.Column="1" Text="+"
                    Style="{StaticResource AddButton}"
                    Command="{Binding GoToAddPageCommand}" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="2*,2*,2*,90">
            <Label Grid.Column="0" Text="Nom"   Style="{StaticResource TableHeaderLabel}" />
            <Label Grid.Column="1" Text="Ville" Style="{StaticResource TableHeaderLabel}" />
            <Label Grid.Column="2" Text="Pays"  Style="{StaticResource TableHeaderLabel}" />
        </Grid>

        <BoxView Grid.Row="2" HeightRequest="1" Margin="0,4,0,0" />

        <RefreshView Grid.Row="3"
                     Command="{Binding LoadItemsCommand}"
                     IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Lieu">
                        <VerticalStackLayout>
                            <Grid ColumnDefinitions="2*,2*,2*,90" Padding="0,8">
                                <Label Grid.Column="0" Text="{Binding Nom}"   Style="{StaticResource TableCellLabel}" />
                                <Label Grid.Column="1" Text="{Binding Ville}" Style="{StaticResource TableCellLabel}" />
                                <Label Grid.Column="2" Text="{Binding Pays}"  Style="{StaticResource TableCellLabel}" />
                                <HorizontalStackLayout Grid.Column="3" Spacing="4"
                                                       VerticalOptions="Center" HorizontalOptions="Center">
                                    <Button Text="✏" Style="{StaticResource EditButton}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LieuCatalogViewModel}}, Path=EditItemCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="🗑" Style="{StaticResource DeleteButton}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LieuCatalogViewModel}}, Path=DeleteItemCommand}"
                                            CommandParameter="{Binding .}" />
                                </HorizontalStackLayout>
                            </Grid>
                            <BoxView HeightRequest="1" Opacity="0.3" Margin="4,0" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>

</ContentPage>
