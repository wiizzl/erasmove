<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Erasmove.ViewModels"
             xmlns:helpers="clr-namespace:Erasmove.Helpers"
             x:Class="Erasmove.Views.AddLieuView"
             x:DataType="vm:AddLieuViewModel">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:StringToDoubleConverter x:Key="StringToDoubleConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="32,24"
                             Spacing="12"
                             HorizontalOptions="Center"
                             MaximumWidthRequest="624">

                <Label Text="Ajouter un Lieu" Style="{StaticResource TablePageTitle}" Margin="0,0,0,8" />

                <Border Style="{StaticResource FormField}">
                    <Entry Placeholder="Nom" Text="{Binding Nom}" />
                </Border>

                <Border Style="{StaticResource FormField}">
                    <Entry Placeholder="Ville" Text="{Binding Ville}" />
                </Border>

                <Border Style="{StaticResource FormField}">
                    <Entry Placeholder="Pays" Text="{Binding Pays}" />
                </Border>

                <Border Style="{StaticResource FormField}">
                    <Entry Placeholder="Latitude"
                           Text="{Binding Latitude, Mode=TwoWay, Converter={StaticResource StringToDoubleConverter}}"
                           Keyboard="Numeric" />
                </Border>

                <Border Style="{StaticResource FormField}">
                    <Entry Placeholder="Longitude"
                           Text="{Binding Longitude, Mode=TwoWay, Converter={StaticResource StringToDoubleConverter}}"
                           Keyboard="Numeric" />
                </Border>

                <ActivityIndicator IsRunning="{Binding IsBusy}" Margin="0,4" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Text="Enregistrer" Command="{Binding SaveCommand}" />
                    <Button Grid.Column="1" Text="Annuler" Command="{Binding CancelCommand}" />
                </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
