<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Erasmove.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Erasmove.Views"
    Title="Erasmove">

    <!-- Auth page: hidden from flyout, shown only at startup if not logged in -->
    <ShellContent
        Route="AuthenticationPage"
        ContentTemplate="{DataTemplate views:AuthenticationPage}"
        Shell.FlyoutItemIsVisible="False" />

    <!-- Main app pages visible in the flyout menu -->
    <ShellContent
        Title="Accueil"
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Mon compte"
        ContentTemplate="{DataTemplate views:AccountPage}"
        Route="AccountPage" />

</Shell>
