<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Erasmove.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Erasmove.Views"
    Title="Erasmove"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent Route="Login" ContentTemplate="{DataTemplate views:LoginView}" />
    
    <TabBar Route="Admin">
        <Tab Title="Lieux">
            <ShellContent ContentTemplate="{DataTemplate views:LieuCatalogView}" />
        </Tab>
        <Tab Title="Transports">
            <ShellContent ContentTemplate="{DataTemplate views:TransportCatalogView}" />
        </Tab>
        <Tab Title="Trajets">
            <ShellContent ContentTemplate="{DataTemplate views:TrajetCatalogView}" />
        </Tab>
        <Tab Title="Voyages">
            <ShellContent ContentTemplate="{DataTemplate views:VoyageCatalogView}" />
        </Tab>
        <Tab Title="Utilisateurs">
            <ShellContent ContentTemplate="{DataTemplate views:UtilisateurCatalogView}" />
        </Tab>
    </TabBar>
    
    <ShellContent Route="Home" ContentTemplate="{DataTemplate views:HomeView}" />

</Shell>
